{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Scene Director",
  "version": "1.0.0-rc.16",
  "identifier": "com.aiscenedirector.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Scene Director",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "GraphicsAndDesign",
    "shortDescription": "Local-first AI scene and shot director"
  }
}
